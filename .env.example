# Supabase (required)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Push Notifications (optional - generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"

# ──────────────────────────────────────────────
# Supabase Edge Function Secrets (set via Supabase CLI or Dashboard)
# These are NOT Vite env vars - set them in Supabase project settings
# ──────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MEMBERSHIP=price_...
# STRIPE_PRICE_TRANSFORMATION=price_...
# STRIPE_PRICE_COACHING=price_...
# STRIPE_DOM_CONNECTED_ACCOUNT_ID=acct_... (if using Stripe Connect)
